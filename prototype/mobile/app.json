{
  "expo": {
    "name": "Mealer",
    "slug": "mealer",
    "version": "1.0.0",
    "scheme": "mealer",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121011",
    "icon": "./assets/mealer-icon.png",
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos so you can scan a grocery receipt.",
          "cameraPermission": "The app needs access to your camera so you can photograph a grocery receipt."
        }
      ],
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "dark",
      "bundleIdentifier": "com.sun.labourlog.mealer"
    },
    "android": {
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/mealer-icon.png",
        "backgroundColor": "#F6F5F0"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/mealer-icon.png"
    }
  }
}
